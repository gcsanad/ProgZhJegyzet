        for (char c : egyediKarakterek) {
            kimenet << c << " ";
        }
        kimenet.close();
        cout << "Egyedi karakterek kimentve a '" << fajlnev << "' fajlba." << endl;
    } else {
        cerr << "Hiba a fajl megnyitasakor!" << endl;
    }
}

int main() {
    srand(static_cast<unsigned>(time(0)));

    // 1. Három egész érték bekérése
    int a, b, c;
    cout << "Adjon meg 3 egesz szamot (szokozzel elvalasztva): ";
    cin >> a >> b >> c;

    // 2. Memóriafoglalás (A három szám összegét használjuk méretként)
    int meret = a + b + c;
    if (meret <= 0) {
        cout << "A meretnek pozitivnak kell lennie!" << endl;
        return 1;
    }
    
    char* karakterek = new char[meret];

    // Feltöltés véletlenszerű kisbetűkkel
    cout << "Eredeti tomb: ";
    for (int i = 0; i < meret; ++i) {
        karakterek[i] = 'a' + rand() % 26;
        cout << karakterek[i];
    }
    cout << endl;

    // 3. Különböző mássalhangzók száma
    int mhDb = kulonbozoMassalhangzok(karakterek, meret);
    cout << "Kulonbozo massalhangzok szama: " << mhDb << endl;

    // 4. Magánhangzók cseréje
    maganhangzoCsere(karakterek, meret);
    cout << "Maganhangzok csereje utan: ";
    for (int i = 0; i < meret; ++i) cout << karakterek[i];
    cout << endl;

    // 5. Karakter törlése
    char torlendok;
    cout << "Adjon meg egy torlendo karaktert: ";
    cin >> torlendok;
    karakterTorles(karakterek, meret, torlendok);
    cout << "Torles utan: ";
    for (int i = 0; i < meret; ++i) cout << karakterek[i];
    cout << endl;

    // +2p: Fájlba írás
    kulonbozoKarakterekFajlba(karakterek, meret, "egyedi_karakterek.txt");

    // Memória felszabadítása
    delete[] karakterek;

    return 0;
}
